      "phase": 0,
      "order": 1,
      "title": "受付スペースを決める",
      "duration_minutes": 5,
      "instructions": [
        "入口近くで風雨が当たらない場所を選ぶ",
        "机1台・椅子2脚を運ぶ",
        "「受付」の張り紙を貼る"
      ],
      "completion_condition": "机が置かれ、看板が見える",
      "troubles": [
